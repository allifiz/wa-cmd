{
  "name": "wa-cmd",
  "version": "0.1.0",
  "description": "Lightweight WhatsApp terminal client powered by Baileys.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "wa-cmd": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "whatsapp",
    "cli",
    "terminal",
    "baileys"
  ],
  "author": "allifiz",
  "license": "MIT",
  "dependencies": {
