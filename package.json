    "chalk": "^5.3.0",
    "qrcode-terminal": "^0.12.0",
    "readline-sync": "^1.4.10",
    "pino": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/readline-sync": "^1.4.8",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
