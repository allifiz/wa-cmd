{
  "name": "wa-cmd",
  "version": "0.3.0",
  "description": "Lightweight WhatsApp terminal client powered by Baileys.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "wa-cmd": "./dist/index.js"
  },
  "scripts": {
    "patch:runtime": "node scripts/apply-runtime-patches.mjs",
    "dev": "npm run patch:runtime && tsx src/index.ts",
    "build": "npm run patch:runtime && tsc",
    "start": "node dist/index.js",
    "import-vcf": "tsx src/import-vcf.ts",
    "cache:list": "node scripts/cache-admin.mjs list",
    "cache:merge": "node scripts/cache-admin.mjs merge",
    "cache:remove": "node scripts/cache-admin.mjs remove",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "whatsapp",
    "cli",
    "terminal",
    "baileys"
  ],
  "author": "allifiz",
  "license": "MIT",
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.18",
    "chalk": "^5.3.0",
    "node-notifier": "^10.0.1",
    "pino": "^9.4.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/qrcode-terminal": "^0.12.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
